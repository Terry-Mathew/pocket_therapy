# PocketTherapy Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# Development Environment (for local development and testing)
EXPO_PUBLIC_SUPABASE_DEV_URL=https://your-dev-project.supabase.co
EXPO_PUBLIC_SUPABASE_DEV_ANON_KEY=your-dev-anon-key-here

# Production Environment (for app store releases)
EXPO_PUBLIC_SUPABASE_PROD_URL=https://your-prod-project.supabase.co
EXPO_PUBLIC_SUPABASE_PROD_ANON_KEY=your-prod-anon-key-here

# ============================================================================
# GOOGLE OAUTH CONFIGURATION
# ============================================================================

# Google OAuth Client IDs (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your-web-client-id.apps.googleusercontent.com

# ============================================================================
# OPENAI CONFIGURATION (for AI features)
# ============================================================================

# OpenAI API Key (for personalized exercise generation)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================================
# ANALYTICS CONFIGURATION (optional)
# ============================================================================

# Analytics service keys (if using analytics)
EXPO_PUBLIC_ANALYTICS_KEY=your-analytics-key-here

# ============================================================================
# PUSH NOTIFICATIONS (optional)
# ============================================================================

# Expo Push Notification service (automatically configured by Expo)
# No manual configuration needed for Expo push notifications

# ============================================================================
# DEVELOPMENT CONFIGURATION
# ============================================================================

# Debug mode (automatically set by Expo based on build type)
# DEBUG=true

# ============================================================================
# SECURITY NOTES
# ============================================================================

# IMPORTANT SECURITY GUIDELINES:
# 
# 1. NEVER commit the actual .env file to version control
# 2. Use different keys for development and production
# 3. Rotate keys regularly, especially if compromised
# 4. Use Supabase RLS policies to secure your database
# 5. Keep your Google OAuth client secrets secure
# 6. Monitor API usage to detect unauthorized access
#
# The EXPO_PUBLIC_ prefix makes variables available to the client-side code.
# Only use this prefix for non-sensitive configuration that's safe to expose.
# 
# For sensitive server-side operations, use environment variables without
# the EXPO_PUBLIC_ prefix and access them only in server-side code.

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# 1. Create Supabase Projects:
#    - Go to https://supabase.com
#    - Create a new project for development
#    - Create a new project for production
#    - Copy the URL and anon key for each project
#
# 2. Set up Google OAuth:
#    - Go to https://console.cloud.google.com
#    - Create a new project or select existing
#    - Enable Google+ API
#    - Create OAuth 2.0 credentials for iOS, Android, and Web
#    - Configure authorized redirect URIs
#
# 3. Configure Supabase Authentication:
#    - In each Supabase project, go to Authentication > Settings
#    - Add Google as an OAuth provider
#    - Enter your Google OAuth client ID and secret
#    - Configure redirect URLs
#
# 4. Set up Database Schema:
#    - Run the database migration scripts
#    - Configure Row Level Security policies
#    - Test authentication flow
#
# 5. Test Configuration:
#    - Start the development server
#    - Test Google OAuth login
#    - Verify database connections
#    - Check that guest mode works
